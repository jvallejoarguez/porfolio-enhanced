{
  "name": "javier-vallejo-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir .ssr",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run typecheck && npm run build:client && npm run build:ssr && npm run prerender",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:links": "node scripts/check-links.mjs",
    "validate": "npm run lint && npm run test:run && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.544.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.3.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
